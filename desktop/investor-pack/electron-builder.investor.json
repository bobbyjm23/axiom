{
  "appId": "com.sovereignwarden.investorpack",
  "productName": "Sovereign Warden — Investor Pack",
  "directories": {
    "output": "dist/investor",
    "buildResources": "../assets"
  },
  "files": [
    "main-process/**/*",
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "app-bundle",
      "to": "app-bundle"
    }
  ],
  "mac": {
    "category": "public.app-category.business",
    "target": ["dmg", "zip"],
    "icon": "../assets/icon.icns"
  },
  "win": {
    "target": ["nsis"],
    "icon": "../assets/icon.ico"
  },
  "publish": null
}
