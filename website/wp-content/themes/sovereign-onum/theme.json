{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{ "slug": "primary", "color": "#fe4c1c", "name": "Primary Orange" },
				{ "slug": "cyan", "color": "#00c3ff", "name": "Cyan Accent" },
				{ "slug": "blue", "color": "#0160e7", "name": "Blue" },
				{ "slug": "dark", "color": "#1a1b1e", "name": "Dark" },
				{ "slug": "navy", "color": "#0a0f2b", "name": "Navy" },
				{ "slug": "white", "color": "#ffffff", "name": "White" },
				{ "slug": "surface", "color": "#f7f7f7", "name": "Surface" },
				{ "slug": "surface-alt", "color": "#eef3fb", "name": "Surface Alt" },
				{ "slug": "text", "color": "#606060", "name": "Text" },
				{ "slug": "text-dark", "color": "#1a1b1e", "name": "Text Dark" },
				{ "slug": "text-muted", "color": "#a5b7d2", "name": "Text Muted" },
				{ "slug": "text-light", "color": "#ffffff", "name": "Text Light" },
				{ "slug": "border", "color": "#e6e6e6", "name": "Border" },
				{ "slug": "primary-dim", "color": "rgba(254, 76, 28, 0.12)", "name": "Primary Dim" },
				{ "slug": "cyan-dim", "color": "rgba(0, 195, 255, 0.12)", "name": "Cyan Dim" }
			],
			"gradients": [
				{
					"slug": "hero-mesh",
					"gradient": "radial-gradient(ellipse 80% 60% at 85% 20%, rgba(0, 195, 255, 0.18) 0%, transparent 55%), radial-gradient(ellipse 60% 50% at 70% 80%, rgba(1, 96, 231, 0.14) 0%, transparent 50%), radial-gradient(ellipse 40% 40% at 95% 50%, rgba(254, 76, 28, 0.08) 0%, transparent 45%)",
					"name": "Hero Mesh"
				},
				{
					"slug": "cta-gradient",
					"gradient": "linear-gradient(145deg, #0039e4 0%, #04dbf1 100%)",
					"name": "CTA Gradient"
				},
				{
					"slug": "footer-gradient",
					"gradient": "linear-gradient(180deg, #0a0f2b 0%, #121a3a 100%)",
					"name": "Footer Gradient"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Red Hat Text\", system-ui, sans-serif",
					"name": "Red Hat Text",
					"slug": "red-hat-text"
				},
				{
					"fontFamily": "\"Red Hat Display\", system-ui, sans-serif",
					"name": "Red Hat Display",
					"slug": "red-hat-display"
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.875rem", "name": "Small" },
				{ "slug": "medium", "size": "1rem", "name": "Medium" },
				{ "slug": "large", "size": "1.125rem", "name": "Large" },
				{ "slug": "x-large", "size": "1.25rem", "name": "Extra Large" },
				{ "slug": "2xl", "size": "1.5rem", "name": "2XL" },
				{ "slug": "3xl", "size": "2rem", "name": "3XL" },
				{ "slug": "4xl", "size": "2.75rem", "name": "4XL" },
				{ "slug": "5xl", "size": "3.5rem", "name": "5XL" }
			]
		},
		"spacing": {
			"spacingScale": { "steps": 0 },
			"spacingSizes": [
				{ "slug": "xs", "size": "0.5rem", "name": "XS" },
				{ "slug": "sm", "size": "0.75rem", "name": "SM" },
				{ "slug": "md", "size": "1rem", "name": "MD" },
				{ "slug": "lg", "size": "1.5rem", "name": "LG" },
				{ "slug": "xl", "size": "2rem", "name": "XL" },
				{ "slug": "2xl", "size": "4rem", "name": "2XL" },
				{ "slug": "3xl", "size": "5.5rem", "name": "3XL" },
				{ "slug": "4xl", "size": "7rem", "name": "4XL" }
			],
			"units": ["px", "rem", "vh", "vw", "%"]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"blocks": {
			"core/button": {
				"border": { "radius": true }
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--red-hat-text)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.875"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--xl)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--xl)"
			},
			"blockGap": "var(--wp--preset--spacing--xl)"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--cyan)" },
				":hover": {
					"color": { "text": "var(--wp--preset--color--primary)" }
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--red-hat-display)",
					"fontWeight": "900",
					"lineHeight": "1.2"
				},
				"color": { "text": "var(--wp--preset--color--text-dark)" }
			},
			"button": {
				"border": { "radius": "25px" },
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--red-hat-display)",
					"fontWeight": "700",
					"fontSize": "var(--wp--preset--font-size--medium)"
				},
				":hover": {
					"color": {
						"background": "#e8431a",
						"text": "var(--wp--preset--color--white)"
					}
				}
			},
			"h1": {
				"typography": { "fontSize": "var(--wp--preset--font-size--5xl)" }
			},
			"h2": {
				"typography": { "fontSize": "var(--wp--preset--font-size--4xl)" }
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2xl)",
					"fontWeight": "700"
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "500"
				},
				"elements": {
					"link": {
						"color": { "text": "var(--wp--preset--color--text-dark)" },
						":hover": {
							"color": { "text": "var(--wp--preset--color--cyan)" }
						}
					}
				}
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-dark-hero", "title": "Page with Dark Hero", "postTypes": ["page"] }
	]
}
