# =============================================================================
# Sovereign AI Platform — POC Environment Profile
# Copy to .env and fill in secrets before running ./scripts/bootstrap-poc.sh
# =============================================================================

# --- General ---
COMPOSE_PROJECT_NAME=sovereign-ai
PLATFORM_HOST=localhost
PLATFORM_URL=http://localhost:3000

# --- PostgreSQL (LiteLLM spend logs, optional Langfuse) ---
POSTGRES_USER=sovereign
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=sovereign_ai
DATABASE_URL=postgresql://sovereign:change_me_postgres_password@postgres:5432/sovereign_ai

# --- Redis (LiteLLM rate limiting / caching) ---
REDIS_PASSWORD=change_me_redis_password

# --- LiteLLM Gateway ---
LITELLM_MASTER_KEY=sk-sovereign-change-me-32chars-min
GEMINI_API_KEY=your-gemini-api-key
# Get a key at https://aistudio.google.com/apikey

# --- Qdrant Cloud (POC vector DB) ---
# Create cluster at https://cloud.qdrant.io
QDRANT_ENDPOINT=https://your-cluster-id.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-cloud-api-key

# --- AnythingLLM ---
ANYTHINGLLM_IMAGE=mintplexlabs/anythingllm:1.8.5
JWT_SECRET=change_me_jwt_secret_at_least_32_characters_long
SIG_KEY=change_me_sig_key_at_least_32_characters_long
SIG_SALT=change_me_sig_salt_at_least_32_characters_long
ANYTHINGLLM_UID=1000
ANYTHINGLLM_GID=1000

# LLM via LiteLLM (OpenAI-compatible)
LLM_PROVIDER=generic-openai
GENERIC_OPEN_AI_BASE_PATH=http://litellm:4000/v1
GENERIC_OPEN_AI_MODEL_PREF=gemini-pro
GENERIC_OPEN_AI_API_KEY=sk-sovereign-change-me-32chars-min

# Embeddings — use LiteLLM or local; for POC LiteLLM can proxy embedding models
EMBEDDING_ENGINE=generic-openai
EMBEDDING_BASE_PATH=http://litellm:4000/v1
EMBEDDING_MODEL_PREF=text-embedding-004
EMBEDDING_MODEL_MAX_CHUNK_LENGTH=8192
GENERIC_OPEN_AI_EMBEDDING_API_KEY=sk-sovereign-change-me-32chars-min

# Vector DB
VECTOR_DB=qdrant

# Multi-user (enable after first boot via admin UI, or set on fresh install)
DISABLE_TELEMETRY=true

# --- Nginx / TLS (POC: self-signed or HTTP only) ---
NGINX_HTTP_PORT=3000
NGINX_HTTPS_PORT=3443
TLS_ENABLED=false

# --- Langfuse (optional observability) ---
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# --- Branding (applied via AnythingLLM admin UI; documented here for reference) ---
# APP_NAME=Sovereign AI
# COMPANY_NAME=Your Company
