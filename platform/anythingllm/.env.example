# AnythingLLM Docker environment overrides
# Mounted into the container; see docker-compose.yml

SERVER_PORT=3001
STORAGE_DIR=/app/server/storage
DISABLE_TELEMETRY=true
PASSWORDMINCHAR=8

# LLM — LiteLLM gateway (OpenAI-compatible)
LLM_PROVIDER=${LLM_PROVIDER}
GENERIC_OPEN_AI_BASE_PATH=${GENERIC_OPEN_AI_BASE_PATH}
GENERIC_OPEN_AI_MODEL_PREF=${GENERIC_OPEN_AI_MODEL_PREF}
GENERIC_OPEN_AI_API_KEY=${GENERIC_OPEN_AI_API_KEY}

# Embeddings
EMBEDDING_ENGINE=${EMBEDDING_ENGINE}
EMBEDDING_BASE_PATH=${EMBEDDING_BASE_PATH}
EMBEDDING_MODEL_PREF=${EMBEDDING_MODEL_PREF}
EMBEDDING_MODEL_MAX_CHUNK_LENGTH=${EMBEDDING_MODEL_MAX_CHUNK_LENGTH}
GENERIC_OPEN_AI_EMBEDDING_API_KEY=${GENERIC_OPEN_AI_EMBEDDING_API_KEY:-}

# Vector DB — Qdrant
VECTOR_DB=qdrant
QDRANT_ENDPOINT=${QDRANT_ENDPOINT}
QDRANT_API_KEY=${QDRANT_API_KEY}

# Auth
JWT_SECRET=${JWT_SECRET}
SIG_KEY=${SIG_KEY}
SIG_SALT=${SIG_SALT}

# Simple SSO passthrough (enable in Phase 2 with oauth2-proxy)
# SIMPLE_SSO_ENABLED=1
# SIMPLE_SSO_NO_LOGIN=1
