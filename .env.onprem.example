# =============================================================================
# Sovereign AI Platform — On-Prem Environment Profile
# Copy to .env.onprem and use with docker-compose.onprem.yml overlay
# =============================================================================

# --- General ---
COMPOSE_PROJECT_NAME=sovereign-ai-onprem
PLATFORM_HOST=ai.internal.company.com
PLATFORM_URL=https://ai.internal.company.com

# --- PostgreSQL ---
POSTGRES_USER=sovereign
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=sovereign_ai
DATABASE_URL=postgresql://sovereign:change_me_postgres_password@postgres:5432/sovereign_ai

# --- Redis ---
REDIS_PASSWORD=change_me_redis_password

# --- LiteLLM Gateway (on-prem models only) ---
LITELLM_MASTER_KEY=sk-sovereign-change-me-32chars-min
# No external API keys — all inference stays on rack
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Local Qdrant (replaces Qdrant Cloud) ---
QDRANT_ENDPOINT=http://qdrant:6333
QDRANT_API_KEY=

# --- AnythingLLM ---
ANYTHINGLLM_IMAGE=mintplexlabs/anythingllm:1.8.5
JWT_SECRET=change_me_jwt_secret_at_least_32_characters_long
SIG_KEY=change_me_sig_key_at_least_32_characters_long
SIG_SALT=change_me_sig_salt_at_least_32_characters_long
ANYTHINGLLM_UID=1000
ANYTHINGLLM_GID=1000

# LLM via local vLLM (OpenAI-compatible)
LLM_PROVIDER=generic-openai
GENERIC_OPEN_AI_BASE_PATH=http://vllm:8000/v1
GENERIC_OPEN_AI_MODEL_PREF=llama3-enterprise
GENERIC_OPEN_AI_API_KEY=none

# Embeddings via local Ollama
EMBEDDING_ENGINE=ollama
EMBEDDING_BASE_PATH=http://ollama:11434
EMBEDDING_MODEL_PREF=nomic-embed-text
EMBEDDING_MODEL_MAX_CHUNK_LENGTH=8192

# Vector DB — local Qdrant
VECTOR_DB=qdrant

DISABLE_TELEMETRY=true

# --- Nginx / TLS (on-prem: internal CA) ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
TLS_ENABLED=true

# --- MinIO (S3-compatible object store) ---
MINIO_ROOT_USER=sovereign
MINIO_ROOT_PASSWORD=change_me_minio_password
S3_ENDPOINT=http://minio:9000
S3_BUCKET=sovereign-documents
S3_ACCESS_KEY=sovereign
S3_SECRET_KEY=change_me_minio_password

# --- vLLM ---
VLLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=8192

# --- Ollama (embedding + small model fallback) ---
OLLAMA_MODELS=nomic-embed-text llama3.2:3b

# --- Langfuse ---
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# --- SSO (Phase 2 — oauth2-proxy) ---
OAUTH2_PROXY_ENABLED=false
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_PROXY_ISSUER_URL=https://login.microsoftonline.com/your-tenant-id/v2.0
